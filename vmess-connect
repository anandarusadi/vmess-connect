#!/usr/bin/env python3
"""VMess Connect — Kali Linux VMess/Xray tunnel tool"""
import sys, os, json, base64, subprocess, signal, time, pathlib

DIR = pathlib.Path.home() / ".vmess-connect"
CONFIG = DIR / "config.json"
PID_FILE = DIR / "xray.pid"
LOG_FILE = DIR / "xray.log"
PROFILES = DIR / "profiles"
SOCKS_PORT = 10808
HTTP_PORT = 10809

G = "\033[0;32m"; Y = "\033[1;33m"; R = "\033[0;31m"; C = "\033[0;36m"; B = "\033[1m"; N = "\033[0m"

def log(msg, color=N):
    print(f"{color}{msg}{N}")

def setup():
    DIR.mkdir(parents=True, exist_ok=True)
    PROFILES.mkdir(parents=True, exist_ok=True)

def install_xray():
    if subprocess.run(["which", "xray"], capture_output=True).returncode == 0:
        v = subprocess.run(["xray", "version"], capture_output=True, text=True).stdout.strip().split("\n")[0]
        log(f"[OK] Xray already installed: {v}", G)
        return
    log("[...] Installing Xray...", Y)
    subprocess.run(['bash', '-c', 'bash -c "$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install'], check=True)
    log("[OK] Xray installed!", G)

def decode_vmess(link):
    b64 = link.replace("vmess://", "")
    pad = 4 - len(b64) % 4
    if pad < 4:
        b64 += "=" * pad
    return json.loads(base64.b64decode(b64))

def generate_config(data):
    addr = data.get("add", "")
    port = int(data.get("port", 443))
    uuid = data.get("id", "")
    aid = int(data.get("aid", 0))
    scy = data.get("scy", "auto")
    net = data.get("net", "tcp")
    tls = data.get("tls", "")
    sni = data.get("sni", "")
    host = data.get("host", "") or addr
    path = data.get("path", "")
    fp = data.get("fp", "")
    ps = data.get("ps", "vmess")

    log(f"[→] {B}{ps}{N} | {addr}:{port} | {net} {tls} {sni}", C)

    # Build stream settings
    stream = {"network": net}
    if tls == "tls":
        tls_settings = {}
        if sni:
            tls_settings["serverName"] = sni
        if fp:
            tls_settings["fingerprint"] = fp
        stream["security"] = "tls"
        stream["tlsSettings"] = tls_settings

    if net == "ws":
        ws = {}
        if path:
            ws["path"] = path
        if host:
            ws["headers"] = {"Host": host}
        stream["wsSettings"] = ws

    config = {
        "log": {"loglevel": "warning"},
        "inbounds": [
            {"tag": "socks", "listen": "127.0.0.1", "port": SOCKS_PORT,
             "protocol": "socks", "settings": {"udp": True}},
            {"tag": "http", "listen": "127.0.0.1", "port": HTTP_PORT,
             "protocol": "http", "settings": {}}
        ],
        "outbounds": [
            {"tag": "proxy", "protocol": "vmess",
             "settings": {"vnext": [{"address": addr, "port": port,
                          "users": [{"id": uuid, "alterId": aid, "security": scy}]}]},
             "streamSettings": stream},
            {"tag": "direct", "protocol": "freedom", "settings": {}},
            {"tag": "block", "protocol": "blackhole", "settings": {}}
        ],
        "routing": {
            "domainStrategy": "IPIfNonMatch",
            "rules": [
                {"type": "field", "outboundTag": "direct", "domain": ["geosite:private"]},
                {"type": "field", "outboundTag": "direct", "ip": ["geoip:private"]}
            ]
        }
    }

    CONFIG.write_text(json.dumps(config, indent=2))
    return ps

def save_profile(link, data):
    name = data.get("ps", "vmess").replace(" ", "-")
    name = "".join(c for c in name if c.isalnum() or c in "-_")[:30]
    (PROFILES / f"{name}.vmess").write_text(link)
    log(f"[OK] Saved: {name}", G)

def connect():
    # Kill existing
    kill(silent=True)
    if not CONFIG.exists():
        log("[X] No config. Run: vmess-connect <vmess-link>", R)
        return 1
    log("[...] Starting Xray client...", Y)
    proc = subprocess.Popen(
        ["xray", "run", "-c", str(CONFIG)],
        stdout=open(LOG_FILE, "w"), stderr=subprocess.STDOUT
    )
    PID_FILE.write_text(str(proc.pid))
    time.sleep(2)
    if proc.poll() is None:
        log(f"[OK] Connected! PID: {proc.pid}", G)
        print(f"  SOCKS5:  127.0.0.1:{SOCKS_PORT}")
        print(f"  HTTP:    127.0.0.1:{HTTP_PORT}")
        print(f"\n  {C}export ALL_PROXY=socks5://127.0.0.1:{SOCKS_PORT}{N}")
        print(f"  {C}export http_proxy=http://127.0.0.1:{HTTP_PORT}{N}")
        print(f"  {C}export https_proxy=http://127.0.0.1:{HTTP_PORT}{N}")
        print(f"\n  {Y}Disconnect: vmess-connect -k{N}")
    else:
        log("[X] Failed! Check log:", R)
        print(LOG_FILE.read_text()[-500:] if LOG_FILE.exists() else "No log")
        return 1

def kill(silent=False):
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text())
            os.kill(pid, signal.SIGTERM)
            if not silent:
                log(f"[OK] Disconnected (was PID {pid})", G)
        except (ProcessLookupError, ValueError):
            if not silent:
                log("[--] Not running", Y)
        PID_FILE.unlink(missing_ok=True)
    elif not silent:
        # Try killing any xray client
        subprocess.run(["pkill", "-f", f"xray run -c {DIR}"], capture_output=True)
        log("[OK] Killed any xray client", G)

def status():
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text())
            os.kill(pid, 0)
            log(f"[OK] Connected — PID: {pid}", G)
            print(f"  SOCKS5: 127.0.0.1:{SOCKS_PORT} | HTTP: 127.0.0.1:{HTTP_PORT}")
            # Try to get proxy IP
            try:
                ip = subprocess.run(
                    ["curl", "-s", "--max-time", "5", "-x",
                     f"socks5://127.0.0.1:{SOCKS_PORT}", "https://ifconfig.me"],
                    capture_output=True, text=True, timeout=6).stdout.strip()
                if ip:
                    print(f"  Proxy IP: {B}{ip}{N}")
            except: pass
            return
        except (ProcessLookupError, ValueError):
            PID_FILE.unlink(missing_ok=True)
    log("[--] Not connected", Y)

def test():
    if not PID_FILE.exists():
        log("[X] Not connected", R); return 1
    try:
        pid = int(PID_FILE.read_text())
        os.kill(pid, 0)
    except:
        log("[X] Not connected", R); return 1

    print("  SOCKS5... ", end="", flush=True)
    try:
        ip = subprocess.run(
            ["curl", "-s", "--max-time", "10", "-x",
             f"socks5://127.0.0.1:{SOCKS_PORT}", "https://ifconfig.me"],
            capture_output=True, text=True, timeout=12).stdout.strip()
        print(f"{G}OK IP: {ip}{N}" if ip else f"{R}FAIL{N}")
    except: print(f"{R}FAIL{N}")

    print("  HTTP...   ", end="", flush=True)
    try:
        ip = subprocess.run(
            ["curl", "-s", "--max-time", "10", "-x",
             f"http://127.0.0.1:{HTTP_PORT}", "https://ifconfig.me"],
            capture_output=True, text=True, timeout=12).stdout.strip()
        print(f"{G}OK IP: {ip}{N}" if ip else f"{R}FAIL{N}")
    except: print(f"{R}FAIL{N}")

def list_profiles():
    log("Saved profiles:", B)
    found = False
    for f in sorted(PROFILES.glob("*.vmess")):
        found = True
        try:
            data = decode_vmess(f.read_text().strip())
            ps = data.get("ps", "?")
            addr = f"{data.get('add','?')}:{data.get('port','?')}"
            print(f"  {G}{f.stem}{N} — {ps} ({addr})")
        except:
            print(f"  {f.stem} — (invalid)")
    if not found:
        print("  (none)")

def usage():
    print(f"""{C}╔══════════════════════════════════════╗{N}
{C}║{N}  {B}VMess Connect{N} — Kali Linux Tunnel    {C}║{N}
{C}╚══════════════════════════════════════╝{N}

  {G}Usage:{N}
  vmess-connect <vmess://...>     Connect using VMess link
  vmess-connect -f <file>         Connect from file
  vmess-connect -s                Status check
  vmess-connect -k                Disconnect
  vmess-connect -t                Test connection
  vmess-connect -i                Install Xray
  vmess-connect -l                List saved profiles
  vmess-connect -p <name>         Connect to saved profile

  {Y}After connect:{N}
  SOCKS5:  127.0.0.1:{SOCKS_PORT}
  HTTP:    127.0.0.1:{HTTP_PORT}

  {C}export ALL_PROXY=socks5://127.0.0.1:{SOCKS_PORT}{N}
  {C}export http_proxy=http://127.0.0.1:{HTTP_PORT}{N}
""")

def main():
    setup()
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        usage()
    elif args[0] == "-i":
        install_xray()
    elif args[0] == "-s":
        status()
    elif args[0] == "-k":
        kill()
    elif args[0] == "-t":
        test()
    elif args[0] == "-l":
        list_profiles()
    elif args[0] == "-p" and len(args) > 1:
        f = PROFILES / f"{args[1]}.vmess"
        if not f.exists():
            log(f"[X] Profile not found: {args[1]}", R); list_profiles(); sys.exit(1)
        link = f.read_text().strip()
        data = decode_vmess(link)
        generate_config(data)
        connect()
    elif args[0] == "-f" and len(args) > 1:
        content = pathlib.Path(args[1]).read_text()
        import re
        link = re.search(r'vmess://[A-Za-z0-9+/=]+', content)
        if not link:
            log("[X] No vmess:// link in file", R); sys.exit(1)
        data = decode_vmess(link.group())
        generate_config(data)
        save_profile(link.group(), data)
        connect()
    elif args[0].startswith("vmess://"):
        data = decode_vmess(args[0])
        generate_config(data)
        save_profile(args[0], data)
        connect()
    else:
        log(f"[X] Unknown: {args[0]}", R); usage(); sys.exit(1)

if __name__ == "__main__":
    main()

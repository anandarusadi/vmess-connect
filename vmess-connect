#!/usr/bin/env python3
"""VMess Connect — Kali Linux VMess/Xray tunnel tool (TUN mode like NetMod)"""
import sys, os, json, base64, subprocess, signal, time, pathlib, re

DIR = pathlib.Path.home() / ".vmess-connect"
CONFIG = DIR / "config.json"
PID_FILE = DIR / "xray.pid"
TUN_PID_FILE = DIR / "tun2socks.pid"
LOG_FILE = DIR / "xray.log"
PROFILES = DIR / "profiles"
SOCKS_PORT = 10808
HTTP_PORT = 10809
TUN_DEV = "vmess0"
TUN_IP = "10.0.85.1"
TUN_GW = "10.0.85.2"
TUN_MASK = "255.255.255.0"

G = "\033[0;32m"; Y = "\033[1;33m"; R = "\033[0;31m"; C = "\033[0;36m"; B = "\033[1m"; N = "\033[0m"

def log(msg, color=N): print(f"{color}{msg}{N}")

def setup():
    DIR.mkdir(parents=True, exist_ok=True)
    PROFILES.mkdir(parents=True, exist_ok=True)

def run(cmd, **kw):
    """Run command, return CompletedProcess"""
    return subprocess.run(cmd, capture_output=True, text=True, **kw)

def install_deps():
    # --- Xray ---
    if run(["which", "xray"]).returncode == 0:
        v = run(["xray", "version"]).stdout.strip().split("\n")[0]
        log(f"[OK] Xray: {v}", G)
    else:
        log("[...] Installing Xray...", Y)
        r = subprocess.run(
            ['bash', '-c', 'bash -c "$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install'],
            capture_output=True, text=True, timeout=120)
        if r.returncode == 0:
            log("[OK] Xray installed!", G)
        else:
            log("[X] Xray install failed!", R)
            log(r.stderr[-300:] if r.stderr else r.stdout[-300:])
            sys.exit(1)

    # --- tun2socks (optional) ---
    if run(["which", "tun2socks"]).returncode == 0:
        log("[OK] tun2socks: installed", G)
        return

    log("[...] Installing tun2socks (TUN mode)...", Y)
    arch = os.uname().machine
    goarch = {"x86_64": "amd64", "aarch64": "arm64"}.get(arch, "amd64")

    # Try multiple URLs
    urls = [
        f"https://github.com/xjasonlyu/tun2socks/releases/download/v2.6.0/tun2socks-linux-{goarch}-v3.zip",
        f"https://github.com/xjasonlyu/tun2socks/releases/download/v2.6.0/tun2socks-linux-{goarch}.zip",
        f"https://github.com/xjasonlyu/tun2socks/releases/download/v2.5.1/tun2socks-linux-{goarch}-v3.zip",
    ]

    downloaded = False
    tmp = DIR / "tun2socks.zip"
    for url in urls:
        log(f"  Trying: {url.split('/')[-1]}", C)
        r = run(["curl", "-sL", "--max-time", "30", "-o", str(tmp), url])
        if r.returncode == 0 and tmp.exists() and tmp.stat().st_size > 1000:
            downloaded = True
            break
        log(f"  Failed (exit {r.returncode})", Y)

    if not downloaded:
        log("[!] tun2socks download failed — no TUN mode", Y)
        log("    Proxy-only mode still works (SOCKS5 + HTTP)", Y)
        log("    After connect run:", Y)
        log("      export ALL_PROXY=socks5://127.0.0.1:10808", Y)
        return

    # Extract
    run(["unzip", "-o", str(tmp), "-d", str(DIR)])

    # Find binary
    for f in DIR.glob("tun2socks*"):
        if f.is_file() and f.suffix not in (".zip", ".txt") and "tun2socks" in f.name:
            os.chmod(f, 0o755)
            r = run(["sudo", "cp", str(f), "/usr/local/bin/tun2socks"])
            if r.returncode == 0:
                log("[OK] tun2socks installed!", G)
                return

    log("[!] tun2socks binary not found in zip", Y)

def decode_vmess(link):
    b64 = link.replace("vmess://", "")
    pad = 4 - len(b64) % 4
    if pad < 4: b64 += "=" * pad
    return json.loads(base64.b64decode(b64))

def generate_config(data):
    addr = data.get("add", "")
    port = int(data.get("port", 443))
    uuid = data.get("id", "")
    aid = int(data.get("aid", 0))
    scy = data.get("scy", "auto")
    net = data.get("net", "tcp")
    tls = data.get("tls", "")
    sni = data.get("sni", "")
    host = data.get("host", "") or addr
    path = data.get("path", "")
    fp = data.get("fp", "")
    ps = data.get("ps", "vmess")

    log(f"[->] {B}{ps}{N} | {addr}:{port} | {net} {tls} {sni}", C)

    stream = {"network": net}
    if tls == "tls":
        ts = {}
        if sni: ts["serverName"] = sni
        if fp: ts["fingerprint"] = fp
        stream["security"] = "tls"; stream["tlsSettings"] = ts
    if net == "ws":
        ws = {}
        if path: ws["path"] = path
        if host: ws["headers"] = {"Host": host}
        stream["wsSettings"] = ws

    config = {
        "log": {"loglevel": "warning"},
        "inbounds": [
            {"tag": "socks", "listen": "127.0.0.1", "port": SOCKS_PORT,
             "protocol": "socks", "settings": {"udp": True}},
            {"tag": "http", "listen": "127.0.0.1", "port": HTTP_PORT,
             "protocol": "http", "settings": {}}
        ],
        "outbounds": [
            {"tag": "proxy", "protocol": "vmess",
             "settings": {"vnext": [{"address": addr, "port": port,
                          "users": [{"id": uuid, "alterId": aid, "security": scy}]}]},
             "streamSettings": stream},
            {"tag": "direct", "protocol": "freedom", "settings": {}},
            {"tag": "block", "protocol": "blackhole", "settings": {}}
        ],
        "routing": {
            "domainStrategy": "IPIfNonMatch",
            "rules": [
                {"type": "field", "outboundTag": "direct", "domain": ["geosite:private"]},
                {"type": "field", "outboundTag": "direct", "ip": ["geoip:private"]}
            ]
        }
    }
    CONFIG.write_text(json.dumps(config, indent=2))
    return ps

def save_profile(link, data):
    name = data.get("ps", "vmess").replace(" ", "-")
    name = "".join(c for c in name if c.isalnum() or c in "-_")[:30]
    (PROFILES / f"{name}.vmess").write_text(link)
    log(f"[OK] Saved: {name}", G)

def get_default_gw():
    r = run(["ip", "route", "show", "default"])
    parts = r.stdout.strip().split()
    try:
        gw = parts[parts.index("via") + 1]
        dev = parts[parts.index("dev") + 1]
        return gw, dev
    except:
        return None, None

def save_original_route():
    gw, dev = get_default_gw()
    if gw and dev:
        (DIR / "orig_route").write_text(f"{gw} {dev}")
        log(f"[OK] Saved original route: {gw} via {dev}", C)

def has_tun2socks():
    return run(["which", "tun2socks"]).returncode == 0 or (DIR / "tun2socks").exists()

def start_tun():
    if not has_tun2socks():
        log("[!] tun2socks not installed — falling back to proxy-only", Y)
        log("    Use: export ALL_PROXY=socks5://127.0.0.1:10808", Y)
        return False

    save_original_route()

    # Create TUN device
    run(["sudo", "ip", "tuntap", "add", "mode", "tun", "name", TUN_DEV])
    run(["sudo", "ip", "addr", "add", f"{TUN_IP}/24", "dev", TUN_DEV])
    run(["sudo", "ip", "link", "set", TUN_DEV, "up"])

    # Keep route to proxy server via original gateway
    if CONFIG.exists():
        try:
            cfg = json.loads(CONFIG.read_text())
            server_addr = cfg["outbounds"][0]["settings"]["vnext"][0]["address"]
            gw, dev = get_default_gw()
            if gw and dev and server_addr:
                run(["sudo", "ip", "route", "add", f"{server_addr}/32", "via", gw, "dev", dev])
                log(f"[OK] Server route: {server_addr} via {gw}", C)
        except: pass

    # Route all traffic through TUN
    run(["sudo", "ip", "route", "add", "0.0.0.0/1", "via", TUN_GW, "dev", TUN_DEV])
    run(["sudo", "ip", "route", "add", "128.0.0.0/1", "via", TUN_GW, "dev", TUN_DEV])

    # Start tun2socks
    tun_bin = "tun2socks" if run(["which", "tun2socks"]).returncode == 0 else str(DIR / "tun2socks")
    tun_log = str(LOG_FILE).replace("xray.log", "tun2socks.log")

    proc = subprocess.Popen(
        ["sudo", tun_bin,
         "-tun", TUN_DEV,
         "-proxy", f"socks5://127.0.0.1:{SOCKS_PORT}",
         "-tun-dns", "8.8.8.8",
         "-tun-addr", TUN_IP,
         "-tun-gw", TUN_GW,
         "-tun-mask", TUN_MASK,
         "-loglevel", "error"],
        stdout=open(tun_log, "w"), stderr=subprocess.STDOUT)
    TUN_PID_FILE.write_text(str(proc.pid))
    time.sleep(2)

    if proc.poll() is None:
        log("[OK] TUN mode active — ALL traffic through VMess!", G)
        return True
    else:
        log("[!] TUN failed — falling back to proxy-only", Y)
        restore_route()
        return False

def restore_route():
    run(["sudo", "ip", "route", "del", "0.0.0.0/1", "via", TUN_GW, "dev", TUN_DEV])
    run(["sudo", "ip", "route", "del", "128.0.0.0/1", "via", TUN_GW, "dev", TUN_DEV])

    if CONFIG.exists():
        try:
            cfg = json.loads(CONFIG.read_text())
            server_addr = cfg["outbounds"][0]["settings"]["vnext"][0]["address"]
            run(["sudo", "ip", "route", "del", f"{server_addr}/32"])
        except: pass

    run(["sudo", "ip", "tuntap", "del", "mode", "tun", "name", TUN_DEV])

    orig = DIR / "orig_route"
    if orig.exists():
        gw, dev = orig.read_text().strip().split()
        run(["sudo", "ip", "route", "add", "default", "via", gw, "dev", dev])
        log(f"[OK] Restored route: {gw} via {dev}", G)
        orig.unlink(missing_ok=True)

def connect(tun_mode=True):
    kill(silent=True)
    if not CONFIG.exists():
        log("[X] No config. Run: vmess-connect <vmess-link>", R)
        return 1

    log("[...] Starting Xray...", Y)
    proc = subprocess.Popen(
        ["xray", "run", "-c", str(CONFIG)],
        stdout=open(str(LOG_FILE), "w"), stderr=subprocess.STDOUT)
    PID_FILE.write_text(str(proc.pid))
    time.sleep(2)

    if proc.poll() is not None:
        log("[X] Xray failed!", R)
        print(LOG_FILE.read_text()[-500:] if LOG_FILE.exists() else "No log")
        return 1

    log(f"[OK] Xray running — PID: {proc.pid}", G)
    print(f"  SOCKS5:  127.0.0.1:{SOCKS_PORT}")
    print(f"  HTTP:    127.0.0.1:{HTTP_PORT}")

    if tun_mode:
        print()
        log("[...] Starting TUN mode...", Y)
        if start_tun():
            print()
            log("=== Semua traffic otomatis lewat VMess ===", G)
            print(f"  {C}Browser, apt, curl, pip — semua{N}")
        else:
            print()
            log("=== Proxy-only mode ===", Y)
            print(f"  {C}export ALL_PROXY=socks5://127.0.0.1:{SOCKS_PORT}{N}")
            print(f"  {C}export http_proxy=http://127.0.0.1:{HTTP_PORT}{N}")
            print(f"  {C}export https_proxy=http://127.0.0.1:{HTTP_PORT}{N}")
    else:
        print(f"\n  {C}export ALL_PROXY=socks5://127.0.0.1:{SOCKS_PORT}{N}")
        print(f"  {C}export http_proxy=http://127.0.0.1:{HTTP_PORT}{N}")
        print(f"  {C}export https_proxy=http://127.0.0.1:{HTTP_PORT}{N}")

    print(f"\n  {Y}Disconnect: vmess-connect -k{N}")

def kill(silent=False):
    # Kill tun2socks + restore routes
    if TUN_PID_FILE.exists():
        try:
            pid = int(TUN_PID_FILE.read_text())
            os.kill(pid, signal.SIGTERM)
            run(["sudo", "kill", str(pid)])
        except: pass
        TUN_PID_FILE.unlink(missing_ok=True)
    restore_route()

    # Kill xray
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text())
            os.kill(pid, signal.SIGTERM)
            if not silent: log(f"[OK] Disconnected (PID {pid})", G)
        except (ProcessLookupError, ValueError):
            if not silent: log("[--] Not running", Y)
        PID_FILE.unlink(missing_ok=True)
    elif not silent:
        run(["pkill", "-f", f"xray run -c {DIR}"])
        log("[OK] Killed", G)

def status():
    connected = False
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text())
            os.kill(pid, 0)
            log(f"[OK] Xray — PID: {pid}", G)
            print(f"  SOCKS5: 127.0.0.1:{SOCKS_PORT} | HTTP: 127.0.0.1:{HTTP_PORT}")
            connected = True
        except: PID_FILE.unlink(missing_ok=True)

    if TUN_PID_FILE.exists():
        try:
            pid = int(TUN_PID_FILE.read_text())
            os.kill(pid, 0)
            log(f"[OK] TUN mode — PID: {pid}", G)
            connected = True
        except: TUN_PID_FILE.unlink(missing_ok=True)

    if connected:
        try:
            ip = run(["curl", "-s", "--max-time", "5", "-x",
                 f"socks5://127.0.0.1:{SOCKS_PORT}", "https://ifconfig.me"],
                timeout=6).stdout.strip()
            if ip: print(f"  Proxy IP: {B}{ip}{N}")
        except: pass
    else:
        log("[--] Not connected", Y)

def test():
    if not PID_FILE.exists():
        log("[X] Not connected", R); return 1
    try:
        pid = int(PID_FILE.read_text())
        os.kill(pid, 0)
    except:
        log("[X] Not connected", R); return 1

    for name, proxy in [("SOCKS5", f"socks5://127.0.0.1:{SOCKS_PORT}"),
                        ("HTTP", f"http://127.0.0.1:{HTTP_PORT}")]:
        print(f"  {name}... ", end="", flush=True)
        try:
            ip = run(["curl", "-s", "--max-time", "10", "-x", proxy,
                "https://ifconfig.me"], timeout=12).stdout.strip()
            print(f"{G}OK IP: {ip}{N}" if ip else f"{R}FAIL{N}")
        except: print(f"{R}FAIL{N}")

def list_profiles():
    log("Saved profiles:", B); found = False
    for f in sorted(PROFILES.glob("*.vmess")):
        found = True
        try:
            data = decode_vmess(f.read_text().strip())
            print(f"  {G}{f.stem}{N} — {data.get('ps','?')} ({data.get('add','?')}:{data.get('port','?')})")
        except: print(f"  {f.stem} — (invalid)")
    if not found: print("  (none)")

def usage():
    print(f"""{C}===================================={N}
  {B}VMess Connect{N} — Kali Linux (NetMod style)
{C}===================================={N}

  vmess-connect <vmess://...>     Connect (TUN mode)
  vmess-connect -P <vmess://...>  Proxy-only (no TUN)
  vmess-connect -f <file>         From file
  vmess-connect -p <name>         Saved profile
  vmess-connect -s                Status
  vmess-connect -k                Disconnect
  vmess-connect -t                Test
  vmess-connect -i                Install deps
  vmess-connect -l                List profiles

  {Y}TUN mode (default):{N} Semua traffic otomatis lewat VMess
  {C}Proxy-only (-P):{N}    Hanya SOCKS5 + HTTP proxy
""")

def main():
    setup()
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"): usage()
    elif args[0] == "-i": install_deps()
    elif args[0] == "-s": status()
    elif args[0] == "-k": kill()
    elif args[0] == "-t": test()
    elif args[0] == "-l": list_profiles()
    elif args[0] == "-p" and len(args) > 1:
        f = PROFILES / f"{args[1]}.vmess"
        if not f.exists(): log(f"[X] Not found: {args[1]}", R); list_profiles(); sys.exit(1)
        data = decode_vmess(f.read_text().strip())
        generate_config(data); connect(tun_mode=True)
    elif args[0] == "-f" and len(args) > 1:
        content = pathlib.Path(args[1]).read_text()
        link = re.search(r'vmess://[A-Za-z0-9+/=]+', content)
        if not link: log("[X] No vmess:// link in file", R); sys.exit(1)
        data = decode_vmess(link.group())
        generate_config(data); save_profile(link.group(), data); connect(tun_mode=True)
    elif args[0] == "-P" and len(args) > 1:
        data = decode_vmess(args[1])
        generate_config(data); save_profile(args[1], data); connect(tun_mode=False)
    elif args[0].startswith("vmess://"):
        data = decode_vmess(args[0])
        generate_config(data); save_profile(args[0], data); connect(tun_mode=True)
    else: log(f"[X] Unknown: {args[0]}", R); usage(); sys.exit(1)

if __name__ == "__main__": main()

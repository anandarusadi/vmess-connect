#!/usr/bin/env python3
"""VMess Connect v4 — Kali Linux transparent proxy (like NetMod)
No tun2socks needed — uses iptables + xray redirect mode"""
import sys, os, json, base64, subprocess, signal, time, pathlib, re, socket

DIR = pathlib.Path.home() / ".vmess-connect"
PROFILES = DIR / "profiles"
PID_FILE = DIR / "xray.pid"
LOG_FILE = DIR / "xray.log"
ORIG_DNS = DIR / "orig_dns"
ORIG_ROUTE = DIR / "orig_route"
SOCKS_PORT = 10808
HTTP_PORT = 10809
REDIRECT_PORT = 12345
DNS_PORT = 1053

G = "\033[0;32m"; Y = "\033[1;33m"; R = "\033[0;31m"; C = "\033[0;36m"; B = "\033[1m"; N = "\033[0m"

def log(msg, color=N): print(f"{color}{msg}{N}")
def run(cmd, **kw): return subprocess.run(cmd, capture_output=True, text=True, **kw)

def setup():
    DIR.mkdir(parents=True, exist_ok=True)
    PROFILES.mkdir(parents=True, exist_ok=True)

def install_xray():
    if run(["which", "xray"]).returncode == 0:
        v = run(["xray", "version"]).stdout.strip().split("\n")[0]
        log(f"[OK] Xray: {v}", G); return
    log("[...] Installing Xray...", Y)
    r = subprocess.run(
        ['bash', '-c', 'bash -c "$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install'],
        capture_output=True, text=True, timeout=120)
    if r.returncode == 0: log("[OK] Xray installed!", G)
    else: log("[X] Xray install failed!", R); sys.exit(1)

def decode_vmess(link):
    b64 = link.replace("vmess://", "")
    pad = 4 - len(b64) % 4
    if pad < 4: b64 += "=" * pad
    return json.loads(base64.b64decode(b64))

def resolve_server_ip(addr):
    """Resolve server domain to IP (for iptables rules)"""
    try:
        return socket.gethostbyname(addr)
    except:
        # Try with system DNS
        r = run(["dig", "+short", addr])
        ip = r.stdout.strip().split("\n")[0] if r.stdout.strip() else ""
        if ip: return ip
        # Last resort: just return addr (might be IP already)
        return addr

def generate_config(data, tproxy=False):
    addr = data.get("add", "")
    port = int(data.get("port", 443))
    uuid = data.get("id", "")
    aid = int(data.get("aid", 0))
    scy = data.get("scy", "auto")
    net = data.get("net", "tcp")
    tls = data.get("tls", "")
    sni = data.get("sni", "")
    host = data.get("host", "") or addr
    path = data.get("path", "")
    fp = data.get("fp", "")
    ps = data.get("ps", "vmess")

    log(f"[->] {B}{ps}{N} | {addr}:{port} | {net} {tls} {sni}", C)

    stream = {"network": net}
    if tls == "tls":
        ts = {}
        if sni: ts["serverName"] = sni
        if fp: ts["fingerprint"] = fp
        stream["security"] = "tls"; stream["tlsSettings"] = ts
    if net == "ws":
        ws = {}
        if path: ws["path"] = path
        if host: ws["headers"] = {"Host": host}
        stream["wsSettings"] = ws

    inbounds = [
        {"tag": "socks", "listen": "127.0.0.1", "port": SOCKS_PORT,
         "protocol": "socks", "settings": {"udp": True}},
        {"tag": "http", "listen": "127.0.0.1", "port": HTTP_PORT,
         "protocol": "http", "settings": {}}
    ]

    routing_rules = [
        {"type": "field", "outboundTag": "direct", "domain": ["geosite:private"]},
        {"type": "field", "outboundTag": "direct", "ip": ["geoip:private"]}
    ]

    if tproxy:
        # Add redirect inbound for transparent proxy
        inbounds.append({
            "tag": "redirect", "listen": "127.0.0.1", "port": REDIRECT_PORT,
            "protocol": "redirect", "settings": {}
        })
        # Add DNS server
        dns = {
            "servers": [
                {"address": "https+ip://1.1.1.1/dns-query", "skipFallback": True},
                {"address": "https+ip://8.8.8.8/dns-query", "skipFallback": True},
                {"address": "localhost", "skipFallback": True}
            ],
            "tag": "dns_in",
            "queryStrategy": "UseIP"
        }
    else:
        dns = {"servers": ["1.1.1.1", "8.8.8.8", "localhost"]}

    config = {
        "log": {"loglevel": "warning"},
        "dns": dns,
        "inbounds": inbounds,
        "outbounds": [
            {"tag": "proxy", "protocol": "vmess",
             "settings": {"vnext": [{"address": addr, "port": port,
                          "users": [{"id": uuid, "alterId": aid, "security": scy}]}]},
             "streamSettings": stream},
            {"tag": "direct", "protocol": "freedom", "settings": {}},
            {"tag": "block", "protocol": "blackhole", "settings": {}}
        ],
        "routing": {
            "domainStrategy": "IPIfNonMatch",
            "rules": routing_rules
        }
    }
    CONFIG = DIR / "config.json"
    CONFIG.write_text(json.dumps(config, indent=2))
    return ps

def save_profile(link, data):
    name = data.get("ps", "vmess").replace(" ", "-")
    name = "".join(c for c in name if c.isalnum() or c in "-_")[:30]
    (PROFILES / f"{name}.vmess").write_text(link)
    log(f"[OK] Saved: {name}", G)

def get_default_gw():
    r = run(["ip", "route", "show", "default"])
    parts = r.stdout.strip().split()
    try:
        return parts[parts.index("via") + 1], parts[parts.index("dev") + 1]
    except:
        return None, None

def setup_iptables(server_addr):
    """Set up iptables transparent proxy — ALL TCP+DNS through VMess"""
    # Resolve server IP
    server_ip = resolve_server_ip(server_addr)
    log(f"[OK] Server IP: {server_ip}", C)

    # Save original DNS
    resolv = pathlib.Path("/etc/resolv.conf")
    if resolv.exists():
        ORIG_DNS.write_text(resolv.read_text())

    # Get local network info
    gw, dev = get_default_gw()
    if gw: ORIG_ROUTE.write_text(f"{gw} {dev}")
    local_net = run(["ip", "route"]).stdout
    # Find the local subnet (e.g., 192.168.1.0/24)
    local_subnet = None
    for line in local_net.split("\n"):
        if "src" in line and dev and dev in line:
            parts = line.strip().split()
            if parts: local_subnet = parts[0]; break

    log("[...] Setting up iptables rules...", Y)

    # Create iptables chain for vmess
    run(["sudo", "iptables", "-t", "nat", "-N", "VMESS"])

    # Skip local/private addresses
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "0.0.0.0/8", "-j", "RETURN"])
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "10.0.0.0/8", "-j", "RETURN"])
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "100.64.0.0/10", "-j", "RETURN"])
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "127.0.0.0/8", "-j", "RETURN"])
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "169.254.0.0/16", "-j", "RETURN"])
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "172.16.0.0/12", "-j", "RETURN"])
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "192.168.0.0/16", "-j", "RETURN"])
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "224.0.0.0/4", "-j", "RETURN"])
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", "240.0.0.0/4", "-j", "RETURN"])

    # Skip VMess server itself (IMPORTANT — otherwise infinite loop)
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-d", f"{server_ip}/32", "-j", "RETURN"])

    # Skip xray process itself
    xray_uid = run(["id", "-u", "xray"]).stdout.strip() if run(["id", "xray"]).returncode == 0 else str(os.getuid())
    # Use owner match for current user running xray
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-m", "owner", "--uid-owner", xray_uid, "-j", "RETURN"],
        timeout=5)
    # Also try by process — skip all traffic from xray
    # Redirect everything else to xray redirect port
    run(["sudo", "iptables", "-t", "nat", "-A", "VMESS", "-p", "tcp", "-j", "REDIRECT", "--to-ports", str(REDIRECT_PORT)])

    # Apply VMESS chain to OUTPUT
    run(["sudo", "iptables", "-t", "nat", "-A", "OUTPUT", "-p", "tcp", "-j", "VMESS"])

    # DNS: redirect UDP port 53 to xray DNS port
    run(["sudo", "iptables", "-t", "nat", "-A", "OUTPUT", "-p", "udp", "--dport", "53", "-j", "REDIRECT", "--to-ports", str(DNS_PORT)])

    # Change system DNS to localhost
    try:
        run(["sudo", "bash", "-c", f"echo 'nameserver 127.0.0.1' > /etc/resolv.conf"])
    except: pass

    log("[OK] iptables rules set!", G)

def cleanup_iptables():
    """Remove all iptables rules and restore DNS"""
    log("[...] Cleaning up iptables...", Y)

    # Remove VMESS chain from OUTPUT
    run(["sudo", "iptables", "-t", "nat", "-D", "OUTPUT", "-p", "tcp", "-j", "VMESS"])
    run(["sudo", "iptables", "-t", "nat", "-d", "OUTPUT", "-p", "udp", "--dport", "53", "-j", "REDIRECT", "--to-ports", str(DNS_PORT)])

    # Flush and delete VMESS chain
    run(["sudo", "iptables", "-t", "nat", "-F", "VMESS"])
    run(["sudo", "iptables", "-t", "nat", "-X", "VMESS"])

    # Restore DNS
    if ORIG_DNS.exists():
        try:
            run(["sudo", "cp", str(ORIG_DNS), "/etc/resolv.conf"])
            log("[OK] DNS restored", G)
        except: pass
        ORIG_DNS.unlink(missing_ok=True)
    else:
        # Fallback DNS
        run(["sudo", "bash", "-c", "echo 'nameserver 8.8.8.8' > /etc/resolv.conf"])
        run(["sudo", "bash", "-c", "echo 'nameserver 1.1.1.1' >> /etc/resolv.conf"])

def connect(tproxy=True):
    kill(silent=True)
    CONFIG = DIR / "config.json"
    if not CONFIG.exists():
        log("[X] No config. Run: vmess-connect <vmess-link>", R); return 1

    # Generate tproxy config if needed
    if tproxy:
        try:
            data = decode_vmess((PROFILES / "last.link").read_text().strip()) if (PROFILES / "last.link").exists() else None
            if data: generate_config(data, tproxy=True)
        except: pass

    log("[...] Starting Xray...", Y)
    proc = subprocess.Popen(
        ["xray", "run", "-c", str(CONFIG)],
        stdout=open(str(LOG_FILE), "w"), stderr=subprocess.STDOUT)
    PID_FILE.write_text(str(proc.pid))
    time.sleep(2)

    if proc.poll() is not None:
        log("[X] Xray failed!", R)
        print(LOG_FILE.read_text()[-500:] if LOG_FILE.exists() else "No log")
        return 1

    log(f"[OK] Xray running — PID: {proc.pid}", G)
    print(f"  SOCKS5:  127.0.0.1:{SOCKS_PORT}")
    print(f"  HTTP:    127.0.0.1:{HTTP_PORT}")

    if tproxy:
        # Get server address from config
        try:
            cfg = json.loads(CONFIG.read_text())
            server_addr = cfg["outbounds"][0]["settings"]["vnext"][0]["address"]
            print()
            log("[...] Setting up transparent proxy...", Y)
            setup_iptables(server_addr)
            print()
            log("==========================================", G)
            log("  SEMUA INTERNET LEWAT VMESS", G)
            log("  Chrome, Firefox, apt, curl — semua!", G)
            log("==========================================", G)
        except Exception as e:
            log(f"[!] TProxy failed: {e}", Y)
            log("  Falling back to proxy-only", Y)
            print(f"\n  {C}export ALL_PROXY=socks5://127.0.0.1:{SOCKS_PORT}{N}")
    else:
        print(f"\n  {C}export ALL_PROXY=socks5://127.0.0.1:{SOCKS_PORT}{N}")
        print(f"  {C}export http_proxy=http://127.0.0.1:{HTTP_PORT}{N}")
        print(f"  {C}export https_proxy=http://127.0.0.1:{HTTP_PORT}{N}")

    print(f"\n  {Y}Disconnect: vmess-connect -k{N}")

def kill(silent=False):
    cleanup_iptables()
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text())
            os.kill(pid, signal.SIGTERM)
            if not silent: log(f"[OK] Disconnected (PID {pid})", G)
        except (ProcessLookupError, ValueError):
            if not silent: log("[--] Not running", Y)
        PID_FILE.unlink(missing_ok=True)
    elif not silent:
        run(["pkill", "-f", "xray run"])
        log("[OK] Killed xray", G)

def status():
    connected = False
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text())
            os.kill(pid, 0)
            log(f"[OK] Xray running — PID: {pid}", G)
            connected = True
        except: PID_FILE.unlink(missing_ok=True)

    # Check iptables
    r = run(["sudo", "iptables", "-t", "nat", "-L", "VMESS"])
    if r.returncode == 0 and "VMESS" in r.stdout:
        log("[OK] Transparent proxy active", G)
        connected = True

    if connected:
        try:
            ip = run(["curl", "-s", "--max-time", "5", "-x",
                 f"socks5://127.0.0.1:{SOCKS_PORT}", "https://ifconfig.me"],
                timeout=6).stdout.strip()
            if ip: print(f"  Proxy IP: {B}{ip}{N}")
        except: pass
    else:
        log("[--] Not connected", Y)

def test():
    if not PID_FILE.exists():
        log("[X] Not connected", R); return 1
    try:
        pid = int(PID_FILE.read_text()); os.kill(pid, 0)
    except: log("[X] Not connected", R); return 1

    for name, proxy in [("SOCKS5", f"socks5://127.0.0.1:{SOCKS_PORT}"),
                        ("HTTP", f"http://127.0.0.1:{HTTP_PORT}")]:
        print(f"  {name}... ", end="", flush=True)
        try:
            ip = run(["curl", "-s", "--max-time", "10", "-x", proxy,
                "https://ifconfig.me"], timeout=12).stdout.strip()
            print(f"{G}OK IP: {ip}{N}" if ip else f"{R}FAIL{N}")
        except: print(f"{R}FAIL{N}")

    # Test direct (should also go through proxy if tproxy active)
    print("  Direct... ", end="", flush=True)
    try:
        ip = run(["curl", "-s", "--max-time", "10", "https://ifconfig.me"], timeout=12).stdout.strip()
        print(f"{G}OK IP: {ip}{N}" if ip else f"{R}FAIL{N}")
    except: print(f"{R}FAIL{N}")

def list_profiles():
    log("Saved profiles:", B); found = False
    for f in sorted(PROFILES.glob("*.vmess")):
        found = True
        try:
            data = decode_vmess(f.read_text().strip())
            print(f"  {G}{f.stem}{N} — {data.get('ps','?')} ({data.get('add','?')}:{data.get('port','?')})")
        except: print(f"  {f.stem} — (invalid)")
    if not found: print("  (none)")

def usage():
    print(f"""{C}===================================={N}
  {B}VMess Connect v4{N} — Kali Linux (NetMod style)
{C}===================================={N}

  vmess-connect <vmess://...>     Connect (all traffic through VMess)
  vmess-connect -P <vmess://...>  Proxy-only (terminal only)
  vmess-connect -f <file>         From file
  vmess-connect -p <name>         Saved profile
  vmess-connect -s                Status
  vmess-connect -k                Disconnect
  vmess-connect -t                Test
  vmess-connect -i                Install Xray
  vmess-connect -l                List profiles

  {Y}Default: transparent proxy{N}
  Chrome, Firefox, apt, curl — SEMUA otomatis
  Kayak NetMod di Windows — ga perlu export

  {C}Proxy-only (-P):{N}
  Hanya SOCKS5 + HTTP, terminal apps saja
""")

def main():
    setup()
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"): usage()
    elif args[0] == "-i": install_xray()
    elif args[0] == "-s": status()
    elif args[0] == "-k": kill()
    elif args[0] == "-t": test()
    elif args[0] == "-l": list_profiles()
    elif args[0] == "-p" and len(args) > 1:
        f = PROFILES / f"{args[1]}.vmess"
        if not f.exists(): log(f"[X] Not found: {args[1]}", R); list_profiles(); sys.exit(1)
        link = f.read_text().strip()
        (PROFILES / "last.link").write_text(link)
        data = decode_vmess(link)
        generate_config(data, tproxy=True)
        connect(tproxy=True)
    elif args[0] == "-f" and len(args) > 1:
        content = pathlib.Path(args[1]).read_text()
        link = re.search(r'vmess://[A-Za-z0-9+/=]+', content)
        if not link: log("[X] No vmess:// link in file", R); sys.exit(1)
        (PROFILES / "last.link").write_text(link.group())
        data = decode_vmess(link.group())
        generate_config(data, tproxy=True)
        save_profile(link.group(), data)
        connect(tproxy=True)
    elif args[0] == "-P" and len(args) > 1:
        data = decode_vmess(args[1])
        generate_config(data, tproxy=False)
        save_profile(args[1], data)
        connect(tproxy=False)
    elif args[0].startswith("vmess://"):
        (PROFILES / "last.link").write_text(args[0])
        data = decode_vmess(args[0])
        generate_config(data, tproxy=True)
        save_profile(args[0], data)
        connect(tproxy=True)
    else: log(f"[X] Unknown: {args[0]}", R); usage(); sys.exit(1)

if __name__ == "__main__": main()
